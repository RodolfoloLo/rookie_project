# Backend runtime
DEBUG_MODE=false
DB_ECHO=false
CORS_ORIGINS=http://localhost:5173

# Use docker-compose defaults below when deploying with compose
ASYNC_DATABASE_URL=mysql+aiomysql://app_user:app_password@db:3306/news_app?charset=utf8mb4

# Redis cache settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# AI proxy settings (server-side only)
AI_API_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
AI_MODEL=qwen3-max-preview
DASHSCOPE_API_KEY=
